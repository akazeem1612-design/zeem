# ZEEM AI - Environment Variables
# Copy this file to .env and fill in your keys

# Server
PORT=3000
NODE_ENV=production
ADMIN_API_KEY=change-this-to-a-strong-random-key

# Twilio (get from twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI (get from platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key

# Google Calendar (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/calendar/callback

# Supabase (for production database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend (email service - get from resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_DOMAIN=onboarding@resend.dev

# Admin notifications (your personal email for lead alerts)
ADMIN_NOTIFICATION_EMAIL=your_email@example.com

# Stripe (get from dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_GROWTH_PRICE_ID=your_growth_price_id
STRIPE_SCALE_PRICE_ID=your_scale_price_id
